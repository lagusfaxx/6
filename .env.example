NEXT_PUBLIC_TURN_URLS=turn:openrelay.metered.ca:80,turn:openrelay.metered.ca:443,turns:openrelay.metered.ca:443
NEXT_PUBLIC_TURN_USERNAME=openrelayproject
NEXT_PUBLIC_TURN_CREDENTIAL=openrelayproject

# ── Flow.cl Payment Gateway ──────────────────────────────────────────────────
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_BASE_URL=https://www.flow.cl/api
# URL where Flow POSTs payment confirmations (your API server)
FLOW_CALLBACK_URL=https://api.uzeed.cl/webhooks/flow/payment
# Flow subscription plan ID (created once via POST /plans/setup)
FLOW_PLAN_ID=UZEED_PRO_MENSUAL

# ── Membership pricing ───────────────────────────────────────────────────────
MEMBERSHIP_PRICE_CLP=4990
MEMBERSHIP_DAYS=30
FREE_TRIAL_DAYS=7

# ── Google OAuth (Sign in with Google — clients only) ───────────────────────
# Create a Web OAuth client at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must exactly match GOOGLE_OAUTH_REDIRECT_URI.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Dev: http://localhost:3001/auth/google/callback
# Prod: https://api.uzeed.cl/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/google/callback
