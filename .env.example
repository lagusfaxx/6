NEXT_PUBLIC_TURN_URLS=turn:openrelay.metered.ca:80,turn:openrelay.metered.ca:443,turns:openrelay.metered.ca:443
NEXT_PUBLIC_TURN_USERNAME=openrelayproject
NEXT_PUBLIC_TURN_CREDENTIAL=openrelayproject

# ── Flow.cl Payment Gateway ──────────────────────────────────────────────────
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_BASE_URL=https://www.flow.cl/api
# URL where Flow POSTs payment confirmations (your API server)
FLOW_CALLBACK_URL=https://api.uzeed.cl/webhooks/flow/payment
# Flow subscription plan ID (created once via POST /plans/setup)
FLOW_PLAN_ID=UZEED_PRO_MENSUAL

# ── Membership pricing ───────────────────────────────────────────────────────
MEMBERSHIP_PRICE_CLP=4990
MEMBERSHIP_DAYS=30
FREE_TRIAL_DAYS=7

# ── Google OAuth (Sign in with Google — clients only) ───────────────────────
# Create a Web OAuth client at https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI must exactly match GOOGLE_OAUTH_REDIRECT_URI.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Dev: http://localhost:3001/auth/google/callback
# Prod: https://api.uzeed.cl/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ── WhatsApp Cloud API (Meta) ───────────────────────────────────────────────
# Set up at https://developers.facebook.com/ → My Apps → WhatsApp.
# 1) Get a permanent System User access token  → WHATSAPP_TOKEN
# 2) Copy your phone-number ID (NOT the phone number itself) → WHATSAPP_PHONE_NUMBER_ID
# 3) Pick any string as your webhook verify token             → WHATSAPP_VERIFY_TOKEN
# 4) Subscribe webhook URL  https://<api host>/webhooks/whatsapp  with that token
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_VERIFY_TOKEN=
# Default language for templated messages (e.g. es_CL, es_MX, en_US)
WHATSAPP_TEMPLATE_LANG=es_CL
# Optional: pre-approved template names. The bot uses free-form text inside
# Meta's 24h customer-service window; outside it falls back to these templates.
# WHATSAPP_TEMPLATE_DEFAULT=uzeed_event_v1
# WHATSAPP_TEMPLATE_OTP=uzeed_otp_v1
# WHATSAPP_TEMPLATE_MESSAGE_RECEIVED=uzeed_pending_messages_v1
# WHATSAPP_TEMPLATE_REMINDER_INACTIVE=uzeed_reminder_inactive_v1
