model ProfileReviewSurvey {
  id            String   @id @default(uuid()) @db.Uuid
  profileId     String   @db.Uuid
  reviewerId    String   @db.Uuid
  ratingBody    Int      // 1-10
  ratingFace    Int      // 1-10
  ratingPhotos  Int      // 1-10 que tan parecida a las fotos
  ratingService Int      // 1-10 calidad del servicio
