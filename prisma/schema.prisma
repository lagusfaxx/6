generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ProfileType {
  CLIENT
  VIEWER
  CREATOR
  PROFESSIONAL
  ESTABLISHMENT
  SHOP
}

enum CategoryKind {
  PROFESSIONAL
  ESTABLISHMENT
  SHOP
}

enum ProfessionalTier {
  PREMIUM
  GOLD
  SILVER
}

enum ServiceRequestStatus {
  PENDIENTE_APROBACION
  APROBADO
  ACTIVO
  PENDIENTE_EVALUACION
  FINALIZADO
  RECHAZADO
  CANCELADO_CLIENTE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PreferenceGender {
  MALE
  FEMALE
  ALL
  OTHER
}

enum PaymentStatus {
  PENDING
  VERIFYING
  PAID
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PostType {
  IMAGE
  VIDEO
}

enum NotificationType {
  SUBSCRIPTION_STARTED
  SUBSCRIPTION_RENEWED
  MESSAGE_RECEIVED
  POST_PUBLISHED
  SERVICE_PUBLISHED
  FORUM_REPLY
  FORUM_NEW_THREAD
  BOOKING_UPDATE
  REMINDER_NO_PHOTO
  REMINDER_INACTIVE
  REMINDER_VIDEOCALL_CONFIG
  VIDEOCALL_BOOKED
  SERVICE_REQUEST_NEW
  UMATE_PLAN_ACTIVATED
  UMATE_NEW_SUBSCRIBER
  ADMIN_EVENT
  TRANSFER_REJECTED
}

enum PaymentIntentPurpose {
  CREATOR_SUBSCRIPTION
  SHOP_PLAN
  MEMBERSHIP_PLAN
  TOKEN_PURCHASE
  UMATE_PLAN
  PUBLICATE_GOLD
}

enum PaymentIntentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum PaymentMethod {
  FLOW
  TRANSFER
}

// ── Token / Wallet System ──

enum TokenDepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TokenTxType {
  DEPOSIT
  VIDEOCALL_HOLD
  VIDEOCALL_RELEASE
  VIDEOCALL_REFUND
  VIDEOCALL_COMMISSION
  WITHDRAWAL
  PENALTY
  ADJUSTMENT
  TIP
  PRIVATE_SHOW
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VideocallBookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED_CLIENT
  NO_SHOW_PROFESSIONAL
}

model Wallet {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  balance         Int      @default(0) // available tokens
  heldBalance     Int      @default(0) // tokens held in escrow
  totalEarned     Int      @default(0) // lifetime earned (professionals)
  totalSpent      Int      @default(0) // lifetime spent (clients)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deposits     TokenDeposit[]
  transactions TokenTransaction[]
  withdrawals  WithdrawalRequest[]
}

model TokenDeposit {
  id          String             @id @default(uuid()) @db.Uuid
  walletId    String             @db.Uuid
  amount      Int                // tokens requested
  clpAmount   Int                // CLP paid
  receiptUrl  String?            // uploaded bank transfer receipt (nullable for Flow)
  method      PaymentMethod      @default(TRANSFER)
  paymentIntentId String?        @unique @db.Uuid // links to PaymentIntent for Flow payments
  status      TokenDepositStatus @default(PENDING)
  reviewedBy  String?            @db.Uuid
  reviewedAt  DateTime?
  rejectReason String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([status])
}

model TokenTransaction {
  id          String      @id @default(uuid()) @db.Uuid
  walletId    String      @db.Uuid
  type        TokenTxType
  amount      Int         // positive = credit, negative = debit
  balance     Int         // balance after this tx
  referenceId String?     @db.Uuid // booking, deposit, withdrawal id
  description String?
  createdAt   DateTime    @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
}

model WithdrawalRequest {
  id            String           @id @default(uuid()) @db.Uuid
  walletId      String           @db.Uuid
  amount        Int              // tokens to withdraw
  clpAmount     Int              // CLP equivalent
  bankName      String
  accountType   String           // corriente, vista, ahorro
  accountNumber String
  holderName    String
  holderRut     String
  status        WithdrawalStatus @default(PENDING)
  reviewedBy    String?          @db.Uuid
  reviewedAt    DateTime?
  rejectReason  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([status])
}

// ── Videocall System ──

model VideocallConfig {
  id                String   @id @default(uuid()) @db.Uuid
  professionalId    String   @unique @db.Uuid
  pricePerMinute    Int      // tokens per minute
  minDurationMin    Int      @default(5)
  maxDurationMin    Int      @default(60)
  availableSlots    Json?    // [{ day: 0-6, from: "09:00", to: "22:00" }]
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  professional User              @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  bookings     VideocallBooking[]
}

model VideocallBooking {
  id               String                @id @default(uuid()) @db.Uuid
  configId         String                @db.Uuid
  clientId         String                @db.Uuid
  professionalId   String                @db.Uuid
  scheduledAt      DateTime
  durationMinutes  Int
  totalTokens      Int                   // total cost
  platformFee      Int                   // 10% commission
  professionalPay  Int                   // 90% to professional
  status           VideocallBookingStatus @default(PENDING)
  roomId               String?               // unique room id for the call
  startedAt            DateTime?
  endedAt              DateTime?
  clientJoinedAt       DateTime?             // when client entered the room
  professionalJoinedAt DateTime?             // when professional entered the room
  reminderSentAt       DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  config       VideocallConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  client       User            @relation("ClientVideocalls", fields: [clientId], references: [id], onDelete: Cascade)
  professional User            @relation("ProfessionalVideocalls", fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([professionalId])
  @@index([scheduledAt])
  @@index([status])
}

// ── Live Streaming ──

model LiveStream {
  id               String    @id @default(uuid()) @db.Uuid
  hostId           String    @db.Uuid
  title            String?
  thumbnailUrl     String?   // periodic frame capture from the live video
  isActive         Boolean   @default(true)
  viewerCount      Int       @default(0)
  maxViewers       Int       @default(10)
  privateShowPrice Int?      // tokens — host-configured price for private shows
  totalTipsEarned  Int       @default(0) // running total of tips received this stream
  startedAt        DateTime  @default(now())
  endedAt          DateTime?

  host         User              @relation(fields: [hostId], references: [id], onDelete: Cascade)
  messages     LiveChatMessage[]
  tips         LiveTip[]
  tipOptions   LiveTipOption[]
  privateShows PrivateShow[]

  @@index([hostId])
  @@index([isActive])
}

// ── Live Tips ──

model LiveTip {
  id         String   @id @default(uuid()) @db.Uuid
  streamId   String   @db.Uuid
  senderId   String   @db.Uuid
  receiverId String   @db.Uuid
  amount     Int      // tokens
  message    String?  // optional message with tip
  optionId   String?  @db.Uuid // if tip was for a redeemable option
  createdAt  DateTime @default(now())

  stream LiveStream    @relation(fields: [streamId], references: [id], onDelete: Cascade)
  option LiveTipOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([streamId, createdAt])
  @@index([senderId])
  @@index([receiverId])
}

model LiveTipOption {
  id          String   @id @default(uuid()) @db.Uuid
  streamId    String?  @db.Uuid // null = global option for this host
  hostId      String   @db.Uuid
  label       String   // e.g. "Flash", "Dance", "Song Request"
  price       Int      // tokens
  emoji       String?  // optional emoji icon
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stream LiveStream? @relation(fields: [streamId], references: [id], onDelete: Cascade)
  tips   LiveTip[]

  @@index([hostId])
}

// ── Private Shows ──

model PrivateShow {
  id         String   @id @default(uuid()) @db.Uuid
  streamId   String   @db.Uuid
  hostId     String   @db.Uuid
  buyerId    String   @db.Uuid
  price      Int      // tokens paid
  isActive   Boolean  @default(true)
  startedAt  DateTime @default(now())
  endedAt    DateTime?

  stream LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([streamId])
  @@index([buyerId])
  @@index([hostId])
}


model LiveChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  streamId   String   @db.Uuid
  userId     String   @db.Uuid
  message    String
  createdAt  DateTime @default(now())

  stream LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([streamId, createdAt])
}

// ── Platform Configuration ──

model PlatformConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model User {
  id                  String            @id @default(uuid()) @db.Uuid
  email               String            @unique
  username            String            @unique
  passwordHash        String?
  displayName         String?
  phone               String?
  gender              Gender?
  preferenceGender    PreferenceGender?
  profileType         ProfileType       @default(VIEWER)
  address             String?
  city                String?
  latitude            Float?
  longitude           Float?
  categoryId          String?           @db.Uuid
  isActive            Boolean           @default(true)
  isVerified          Boolean           @default(false)
  verifiedAt          DateTime?
  verifiedByPhone     String?
  tier                ProfessionalTier?
  isOnline            Boolean           @default(false)
  lastSeen            DateTime?
  avatarUrl           String?
  coverUrl            String?
  coverPositionX      Float?
  coverPositionY      Float?
  bio                 String?
  birthdate           DateTime?
  serviceCategory     String?
  serviceDescription  String?
  heightCm            Int?
  weightKg            Int?
  measurements        String?
  hairColor           String?
  skinTone            String?
  languages           String?
  serviceStyleTags    String?
  primaryCategory     String?
  profileTags         String[]          @default([])
  serviceTags         String[]          @default([])
  avgResponseMinutes  Int?
  availabilityNote    String?
  baseRate            Int?
  minDurationMinutes  Int?
  acceptsIncalls      Boolean?
  acceptsOutcalls     Boolean?
  subscriptionPrice   Int?              @default(2500)
  shopTrialEndsAt     DateTime?
  termsAcceptedAt     DateTime?
  allowFreeMessages   Boolean           @default(false)
  role                Role              @default(USER)
  membershipExpiresAt DateTime?
  flowCustomerId      String?           @unique
  flowSubscriptionId  String?           @unique
  flowCardType        String?
  flowCardLast4       String?
  completedServices   Int               @default(0)
  profileViews        Int               @default(0)
  reviewTagsSummary   Json?
  adminManaged        Boolean           @default(false)
  adminQualityScore   Float?
  passwordSetToken          String?
  passwordSetTokenExpiresAt DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  posts                    Post[]
  payments                 Payment[]
  subscriptions            KhipuSubscription[]
  profileSubscriptions     ProfileSubscription[] @relation("ProfileSubscriptions")
  profileSubscriptionsByMe ProfileSubscription[] @relation("ProfileSubscriber")
  services                 ServiceItem[]
  profileMedia             ProfileMedia[]
  paymentIntents           PaymentIntent[]       @relation("SubscriberPaymentIntents")
  profilePaymentIntents    PaymentIntent[]       @relation("ProfilePaymentIntents")
  sentMessages             Message[]             @relation("SentMessages")
  receivedMessages         Message[]             @relation("ReceivedMessages")
  receivedRatings          ServiceRating[]       @relation("ProfileRatings")
  givenRatings             ServiceRating[]       @relation("GivenRatings")
  receivedProfileReviews   ProfileReviewSurvey[] @relation("ProfileReviewsReceived")
  givenProfileReviews      ProfileReviewSurvey[] @relation("ProfileReviewsGiven")
  notifications            Notification[]
  category                 Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  favorites                Favorite[]            @relation("FavoritesByUser")
  favoritedBy              Favorite[]            @relation("FavoritesForProfessional")
  clientRequests           ServiceRequest[]      @relation("ClientRequests")
  professionalRequests     ServiceRequest[]      @relation("ProfessionalRequests")
  products                Product[] @relation("ShopProducts")
  shopCategories         ShopCategory[]
  motelRooms              MotelRoom[] @relation("MotelRooms")
  motelPacks              MotelPack[] @relation("MotelPacks")
  motelPromotions         MotelPromotion[] @relation("MotelPromotions")
  pushSubscriptions      PushSubscription[]
  stories                Story[]
  forumThreads           ForumThread[]
  forumPosts             ForumPost[]
  wallet                 Wallet?
  videocallConfig        VideocallConfig?
  clientVideocalls       VideocallBooking[] @relation("ClientVideocalls")
  professionalVideocalls VideocallBooking[] @relation("ProfessionalVideocalls")
  liveStreams            LiveStream[]

  // Admin profile ratings
  adminRatingsReceived   AdminProfileRating[] @relation("AdminRatingsReceived")
  adminRatingsGiven      AdminProfileRating[] @relation("AdminRatingsGiven")

  // U-Mate relations
  umateCreator           UmateCreator?
  umateSubscriptions     UmateSubscription[]
  umateCreatorSubs       UmateCreatorSub[]   @relation("UmateSubscriber")
  umateLikes             UmateLike[]
  umateComments          UmateComment[]

  // Referral system
  creatorReferralCode    CreatorReferralCode? @relation("CreatorReferralCode")
  referralRedemption     ReferralRedemption?  @relation("ReferralProfessional")
}

model PushSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}


model Post {
  id        String   @id @default(uuid()) @db.Uuid
  authorId  String?  @db.Uuid
  title     String
  body      String
  isPublic  Boolean  @default(false)
  price     Int      @default(0)
  type      PostType @default(IMAGE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
  media  Media[]

  @@index([authorId, createdAt])
}

model Media {
  id        String    @id @default(uuid()) @db.Uuid
  postId    String    @db.Uuid
  type      MediaType
  url       String
  createdAt DateTime  @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @db.Uuid
  khipuPaymentId   String?       @unique
  subscriptionId   String?       @db.Uuid
  amount           Int
  status           PaymentStatus @default(PENDING)
  membershipDays   Int           @default(30)
  paymentUrl       String?
  paidAt           DateTime?
  transactionId    String?
  providerPaymentId String?
  currency         String        @default("CLP")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription KhipuSubscription? @relation("KhipuSubscriptionPayments", fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status, createdAt])
}

model KhipuSubscription {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @db.Uuid
  subscriptionId     String        @unique
  status             String        @default("PENDING")
  redirectUrl        String?
  amount             Int           @default(4990)
  frequency          String        @default("MONTHLY")
  nextPaymentDate    DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[] @relation("KhipuSubscriptionPayments")
}

model ProfileSubscription {
  id           String   @id @default(uuid()) @db.Uuid
  subscriberId String   @db.Uuid
  profileId    String   @db.Uuid
  status       String   @default("ACTIVE")
  price        Int
  startedAt    DateTime @default(now())
  expiresAt    DateTime

  subscriber User @relation("ProfileSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  profile    User @relation("ProfileSubscriptions", fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, profileId])
}

model ServiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  ownerId     String   @db.Uuid
  categoryId  String?  @db.Uuid
  title       String
  description String?
  category    String?
  price       Int?
  address     String?
  latitude    Float?
  longitude   Float?
  approxAreaM Int?
  locationVerified Boolean  @default(false)
  isActive    Boolean  @default(true)
  durationMinutes Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  categoryRel Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  media    ServiceMedia[]
}

model ProfileMedia {
  id        String    @id @default(uuid()) @db.Uuid
  ownerId   String    @db.Uuid
  type      MediaType
  url       String
  createdAt DateTime  @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model ServiceMedia {
  id            String    @id @default(uuid()) @db.Uuid
  serviceItemId String    @db.Uuid
  type          MediaType
  url           String
  createdAt     DateTime  @default(now())

  serviceItem ServiceItem @relation(fields: [serviceItemId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentIntent {
  id                String               @id @default(uuid()) @db.Uuid
  subscriberId      String               @db.Uuid
  profileId         String?              @db.Uuid
  purpose           PaymentIntentPurpose
  method            PaymentMethod        @default(FLOW)
  status            PaymentIntentStatus  @default(PENDING)
  amount            Int
  providerPaymentId String?
  paymentUrl        String?
  notes             String?
  paidAt            DateTime?
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  subscriber User  @relation("SubscriberPaymentIntents", fields: [subscriberId], references: [id], onDelete: Cascade)
  profile    User? @relation("ProfilePaymentIntents", fields: [profileId], references: [id], onDelete: SetNull)
}

model PendingGoldRegistration {
  id        String   @id @default(uuid()) @db.Uuid
  formData  String
  fileUrls  String   @default("[]")
  flowToken String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model Message {
  id        String    @id @default(uuid()) @db.Uuid
  fromId    String    @db.Uuid
  toId      String    @db.Uuid
  body      String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  from User @relation("SentMessages", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("ReceivedMessages", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId])
  @@index([toId])
  @@index([createdAt])
}

model ServiceRating {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @db.Uuid
  raterId   String   @db.Uuid
  rating    Int
  createdAt DateTime @default(now())

  profile User @relation("ProfileRatings", fields: [profileId], references: [id], onDelete: Cascade)
  rater   User @relation("GivenRatings", fields: [raterId], references: [id], onDelete: Cascade)

  @@unique([profileId, raterId])
}

model Category {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  slug           String          @unique
  displayName    String
  kind           CategoryKind
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  professionals  User[]
  establishments Establishment[]
  serviceItems   ServiceItem[]
  products       Product[]
}

model Establishment {
  id           String               @id @default(uuid()) @db.Uuid
  categoryId   String               @db.Uuid
  name         String
  city         String
  address      String
  phone        String
  description  String?
  latitude     Float?
  longitude    Float?
  galleryUrls  String[]             @default([])
  websiteUrl   String?
  externalOnly Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  category Category            @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  reviews  EstablishmentReview[]
}

model Favorite {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  professionalId String   @db.Uuid
  createdAt      DateTime @default(now())

  user         User @relation("FavoritesByUser", fields: [userId], references: [id], onDelete: Cascade)
  professional User @relation("FavoritesForProfessional", fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([userId, professionalId])
  @@index([userId])
}

model ServiceRequest {
  id                    String               @id @default(uuid()) @db.Uuid
  clientId              String               @db.Uuid
  professionalId        String               @db.Uuid
  status                ServiceRequestStatus @default(PENDIENTE_APROBACION)
  requestedDate         String?
  requestedTime         String?
  agreedLocation        String?
  clientComment         String?
  professionalPriceClp  Int?
  professionalDurationM Int?
  professionalComment   String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  client       User               @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  professional User               @relation("ProfessionalRequests", fields: [professionalId], references: [id], onDelete: Cascade)
  review       ProfessionalReview?

  @@index([clientId, status])
  @@index([professionalId, status])
}

model ProfessionalReview {
  id               String   @id @default(uuid()) @db.Uuid
  serviceRequestId String   @unique @db.Uuid
  hearts           Int
  comment          String?
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
}

model EstablishmentReview {
  id              String   @id @default(uuid()) @db.Uuid
  establishmentId String   @db.Uuid
  stars           Int
  comment         String?
  createdAt       DateTime @default(now())

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
}



model Product {
  id          String   @id @default(uuid()) @db.Uuid
  shopId      String   @db.Uuid
  categoryId  String?  @db.Uuid
  shopCategoryId String? @db.Uuid
  name        String
  description String?
  price       Int
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop      User           @relation("ShopProducts", fields: [shopId], references: [id], onDelete: Cascade)
  category  Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  shopCategory ShopCategory? @relation(fields: [shopCategoryId], references: [id], onDelete: SetNull)
  media     ProductMedia[]
}

model ShopCategory {
  id        String   @id @default(uuid()) @db.Uuid
  shopId    String   @db.Uuid
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop      User     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([shopId, slug])
  @@index([shopId])
}

model ProductMedia {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  url       String
  pos       Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model MotelRoom {
